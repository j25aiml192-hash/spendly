{
  "rewrites": [
    { "source": "/dashboard", "destination": "/frontend/dashboard.html" },
    { "source": "/inventory", "destination": "/frontend/inventory.html" },
    { "source": "/spend", "destination": "/frontend/spend.html" },
    { "source": "/alerts", "destination": "/frontend/alerts.html" },
    { "source": "/settings", "destination": "/frontend/settings.html" },
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
